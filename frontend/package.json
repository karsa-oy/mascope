{
  "name": "mascope",
  "author": {
    "name": "www.karsa.fi",
    "email": "support@karsa.fi"
  },
  "description": "Karsa Mascope",
  "homepage": "https://www.karsa.fi",
  "version": "2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite --open",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx playwright test --project=chromium",
    "test:full": "npx playwright test",
    "test:only": "npx playwright test --project=chromium --retries=0 -g",
    "test:headed": "npx playwright test --project=chromium --headed --trace off --timeout 0 --reporter list --project=chromium --retries=0 -g",
    "test:trace": "npx playwright test --project=chromium --trace on --project=chromium --retries=0 -g",
    "test:gen": "npx playwright codegen http://localhost:5173/",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "palette": "node scripts/palette.js"
  },
  "dependencies": {
    "@primevue/themes": "^4.0.2",
    "axios": "^1.7.2",
    "pinia": "^2.1.7",
    "plotly.js-basic-dist": "^2.30.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.2",
    "socket.io-client": "^4.7.5",
    "vue": "^3.4.33",
    "vue-router": "^4.4.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@rushstack/eslint-patch": "^1.3.3",
    "@types/node": "^20.12.12",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "chroma-js": "^2.4.2",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.0.3",
    "vite": "^5.1.5",
    "vite-plugin-toml": "^0.7.0"
  }
}
