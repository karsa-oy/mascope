# PUBLIC - can be exposed to client

MASCOPE_PUBLIC_MODE=production

MASCOPE_PUBLIC_PROTOCOL=ws
MASCOPE_PUBLIC_HOST=192.168.1.127
MASCOPE_PUBLIC_PORT=80
MASCOPE_PUBLIC_API_PORT=8091
MASCOPE_PUBLIC_DB_VERSION=6

# PRIVATE - should not be exposed to client

MASCOPE_PRIVATE_ENV=linux

# MASCOPE_PRIVATE_DATADIR - abs path
MASCOPE_PRIVATE_DATADIR=/mascope_data
MASCOPE_PRIVATE_CONVERTER_DIR=/to_mascope
MASCOPE_PRIVATE_DOWNLOADER_DIR=/from_instrument
MASCOPE_PRIVATE_LOG_DIR=/mascope_log
