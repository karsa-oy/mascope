# Mascope unattended-update configuration.
#
# tooling/ubuntu.sh installs this to /etc/mascope/update.env (chmod 600) and
# mascope-update.service reads it. Edit the values, add a release token, then
# enable the timer:
#
#   sudo systemctl enable --now mascope-update.timer
#
# See docs/maintaining.md for the full picture.

# Apply updates only during these local hours (HH-HH). Unset means "any time
# the timer fires".
MASCOPE_UPDATE_WINDOW=2-5

# Days a migration update waits before it is auto-applied inside the window,
# unless confirmed sooner (`mascope prod update --confirm`) or snoozed
# (`mascope prod update --snooze N`).
MASCOPE_UPDATE_GRACE_DAYS=7

# Repository whose releases are tracked. Override only for a fork or mirror.
# MASCOPE_UPDATE_REPO=karsa-oy/mascope

# The updater discovers releases via the `gh` CLI, which must be authenticated
# even though the repo is public. Set any GitHub token here (no special scopes
# needed) - or, instead, run `gh auth login` as the deploy user.
# GH_TOKEN=
