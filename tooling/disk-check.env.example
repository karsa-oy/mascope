# Configuration for tooling/disk-check.sh (disk-space monitor / alerting).
#
# tooling/ubuntu.sh installs this to /etc/mascope/disk-check.env (chmod 600) and
# mascope-disk-check.service reads it. Every value is optional - with none set,
# the monitor logs to the journal using the built-in defaults but sends no
# external alert. Set HEALTHCHECK_URL to get paged before a disk fills.

# --- Thresholds ---------------------------------------------------------------
# A monitored filesystem is reported (and alerts) when it drops below EITHER:
#   - MIN_FREE_GB  : an absolute floor in GiB (the "about to crash" signal), or
#   - MIN_FREE_PCT : a percentage of the filesystem (an earlier warning).
# On a very large disk, set MIN_FREE_PCT=0 to disable the percentage check so
# you are not paged while tens of GiB are still free.
MIN_FREE_GB=10
MIN_FREE_PCT=10

# Where docker stores image layers, if not the default. Find it with:
#   docker info --format '{{.DockerRootDir}}'
# DOCKER_ROOT=/var/lib/docker

# --- Monitoring (optional) ----------------------------------------------------
# healthchecks.io-style ping URL. On every OK run the script pings <url> (so a
# stalled monitor is itself flagged as missing); when a filesystem is low it
# pings <url>/fail to raise the alert. Use a SEPARATE check from the backup one.
# HEALTHCHECK_URL=https://hc-ping.com/<uuid>
