# GlitchTip configuration. Copy to glitchtip.env on the box and fill SECRET_KEY.
#   cp glitchtip.env.example glitchtip.env
#   sed -i "s|^SECRET_KEY=.*|SECRET_KEY=$(openssl rand -hex 32)|" glitchtip.env
# The real glitchtip.env lives only on the box (192.168.1.88); never commit it.

# --- required -----------------------------------------------------------------
# The only secret GlitchTip strictly needs. Generate: openssl rand -hex 32
SECRET_KEY=

# Postgres DSN. Matches the trust-auth postgres service in compose.yaml. To
# harden: set POSTGRES_PASSWORD=<secret> on the postgres service, drop
# POSTGRES_HOST_AUTH_METHOD, and use postgres://postgres:<secret>@postgres:5432/postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/postgres

# Cache/queue backend. The scheme stays redis:// even though the image is Valkey.
VALKEY_URL=redis://valkey:6379

# Base URL of this GlitchTip instance. The SCHEME IS REQUIRED (http is fine on a
# LAN). This is baked into the DSNs GlitchTip hands out and into email links; if
# it is wrong or unset, event DSNs point at localhost and ingestion breaks.
# Change 192.168.1.88 if the box's LAN address differs.
GLITCHTIP_DOMAIN=http://192.168.1.88:8000

# --- web / process ------------------------------------------------------------
# HTTP + embedded worker + scheduler in one process (GlitchTip 6 default topology).
SERVER_ROLE=all_in_one
# GlitchTip 6 serves via Granian; GRANIAN_PORT (not PORT) sets the in-container
# port. Prefer remapping the host side in compose.yaml ("192.168.1.88:9000:8000")
# to move it, and leave this at 8000.
# GRANIAN_PORT=8000
# SKIP_INIT=False   # default: migrations + partition maintenance run on boot

# --- email --------------------------------------------------------------------
# consolemail:// logs emails instead of sending (fine to start). For real alert
# emails, point EMAIL_URL at your SMTP relay.
DEFAULT_FROM_EMAIL=glitchtip@192.168.1.88
EMAIL_URL=consolemail://
# EMAIL_URL=smtp://user:pass@smtp-relay.lan:587

# --- access control -----------------------------------------------------------
# The FIRST account can still register (there is no default admin); signup locks
# for everyone after that.
ENABLE_USER_REGISTRATION=False
ENABLE_ORGANIZATION_CREATION=False
ENABLE_ADMIN=False

# --- tuning / RAM (optional) --------------------------------------------------
# VTASKS_CONCURRENCY=20          # background task concurrency (NOT the old CELERY_* knob)
# GLITCHTIP_ENABLE_LOGS=False    # disable log ingestion to save RAM/disk
# GLITCHTIP_ENABLE_UPTIME=False  # GlitchTip's own uptime pings (we use Uptime Kuma)
# GLITCHTIP_RETENTION_DAYS=90    # auto-delete events older than N days
