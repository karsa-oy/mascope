# Configuration for tooling/backup-cron.sh (nightly encrypted off-site backups).
#
# Setup:
#   cp tooling/backup.env.example "$MASCOPE_PATH/.runtime/secrets/backup.env"
#   chmod 600 "$MASCOPE_PATH/.runtime/secrets/backup.env"
#
# .runtime/secrets/ is gitignored; never commit the filled-in file.

# --- Off-site repository (restic) --------------------------------------------
# Pick ONE repository form:
#
# Hetzner Storage Box (SFTP; enable SSH support in the Storage Box settings
# and install the host's SSH key first):
#   RESTIC_REPOSITORY=sftp:u123456@u123456.your-storagebox.de:mascope-backups/<hostname>
#
# S3-compatible object storage (e.g. Contabo Object Storage; also set the
# AWS_* credentials below):
#   RESTIC_REPOSITORY=s3:https://eu2.contabostorage.com/<bucket>/mascope-backups/<hostname>
#
# Own backup server reached over a VPN overlay (Tailscale/WireGuard) — see
# "Using your own backup server" in the developer guide:
#   RESTIC_REPOSITORY=sftp:backup@<vpn-ip-or-hostname>:mascope-backups/<hostname>
RESTIC_REPOSITORY=

# Encryption password for the repository. Generate with `openssl rand -base64 32`.
# WITHOUT THIS PASSWORD THE BACKUPS CANNOT BE RESTORED — store a copy in the
# company password manager before the first run.
RESTIC_PASSWORD=

# Only needed for s3: repositories.
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=

# --- What to back up ----------------------------------------------------------
# Host path of the uploaded-files store (the MASCOPE_FILESTORE compose mount).
# Find it with:
#   docker inspect mascope_prod_backend \
#     --format '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}'
# and take the source mounted at .../filestore. Leave empty to back up the
# database only (NOT recommended — raw files are irreplaceable).
FILESTORE_PATH=

# --- Retention ----------------------------------------------------------------
# Days to keep .dump files on the local disk (fast restores).
LOCAL_RETENTION_DAYS=7
# Off-site snapshot policy (restic forget).
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# --- Monitoring (optional) ----------------------------------------------------
# healthchecks.io-style ping URL; the script pings it on success and
# <url>/fail on failure, so a silently broken cron job still alerts you.
#HEALTHCHECK_URL=https://hc-ping.com/<uuid>
