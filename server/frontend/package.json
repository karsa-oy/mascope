{
  "name": "mascope",
  "author": {
    "name": "www.karsa.fi",
    "email": "support@karsa.fi"
  },
  "description": "Karsa Mascope",
  "homepage": "https://www.karsa.fi",
  "version": "2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite --open",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx playwright test --project=e2e",
    "test:e2e": "npx playwright test --project=e2e",
    "test:e2e:full": "npx playwright test --project=e2e --project=e2e-firefox --project=e2e-webkit",
    "test:instrument": "npx playwright test --project=instrument",
    "test:only": "npx playwright test --project=e2e --retries=0 -g",
    "test:headed": "npx playwright test --project=e2e --headed --trace off --timeout 0 --reporter list --retries=0 -g",
    "test:trace": "npx playwright test --project=e2e --trace on --retries=0 -g",
    "test:gen": "npx playwright codegen http://localhost:8080/",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "palette": "node scripts/palette.js",
    "clean": "npm run clean:windows && npm run clean:linux",
    "clean:windows": "node -e \"if (process.platform === 'win32') process.exit(1)\" || , if exist node_modules rmdir /Q /S node_modules",
    "clean:linux": "node -e \"if (process.platform !== 'win32') process.exit(1)\" || rm -rf node_modules"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.9",
    "@phosphor-icons/web": "^2.1.2",
    "@primevue/themes": "^4.5.4",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/drop-target": "^4.1.0",
    "@uppy/tus": "^5.1.0",
    "@uppy/vue": "^3.1.0",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "plotly.js-dist-min": "^3.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@rushstack/eslint-patch": "^1.15.0",
    "@types/node": "^25.0.9",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "chroma-js": "^3.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.0",
    "vite": "^7.3.1"
  },
  "overrides": {}
}
