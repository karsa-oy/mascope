repository-code: "https://github.com/karsa-oy/mascope"
url: "https://github.com/karsa-oy/mascope"
license: Apache-2.0
version: 1.0.0
date-released: "2026-06-29"
# Bumped per release: `version` + `doi` (the version DOI) identify this exact
# release for reproducible citation; the concept DOI under `identifiers` always
# resolves to the latest version (and is what the README badge links to).
doi: "10.5281/zenodo.21037635"
identifiers:
  - type: doi
    value: "10.5281/zenodo.21037634"
    description: Concept DOI - always resolves to the latest Mascope release.
