# PUBLIC - can be exposed to client

MASCOPE_PUBLIC_MODE=production

MASCOPE_PUBLIC_API_PROTOCOL=ws
MASCOPE_PUBLIC_API_HOST=localhost
MASCOPE_PUBLIC_API_PORT=80
MASCOPE_PUBLIC_PROXY_API_PORT=8091
MASCOPE_PUBLIC_DB_VERSION=1

# PRIVATE - should not be exposed to client

MASCOPE_PRIVATE_ENV=linux

# MASCOPE_PRIVATE_DATADIR - abs path, or relative to backend
MASCOPE_PRIVATE_DATADIR="/mascope_data"