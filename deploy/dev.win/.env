# PUBLIC - can be exposed to client

MASCOPE_PUBLIC_MODE=development

MASCOPE_PUBLIC_PROTOCOL=ws
MASCOPE_PUBLIC_HOST=192.168.1.11
MASCOPE_PUBLIC_PORT=8080
MASCOPE_PUBLIC_API_PORT=8090
MASCOPE_PUBLIC_DB_VERSION=2

# PRIVATE - should not be exposed to client

MASCOPE_PRIVATE_ENV=win

# MASCOPE_PRIVATE_DATADIR - abs path, or relative to backend
MASCOPE_PRIVATE_DATADIR=D:/Data