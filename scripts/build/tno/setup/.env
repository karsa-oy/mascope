# PUBLIC - can be exposed to client

MASCOPE_PUBLIC_MODE=production

MASCOPE_PUBLIC_PORT=80
MASCOPE_PUBLIC_API_PORT=8091
MASCOPE_PUBLIC_DB_VERSION=12

# PRIVATE - should not be exposed to client

MASCOPE_PRIVATE_ENV=linux

MASCOPE_PRIVATE_DATABASE_DIR=$HOME/shared/mascope_data/database
MASCOPE_PRIVATE_INSTRUMENT_DIR=$HOME/shared/mascope_data/instrument
MASCOPE_PRIVATE_CONVERTER_DIR=$HOME/shared/to_mascope
MASCOPE_PRIVATE_LOG_DIR=$HOME/mascope_log
MASCOPE_PRIVATE_CONFIG_DIR=$HOME/mascope_config
